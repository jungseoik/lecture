# K-Study Match 환경변수 예시. 복사해서 .env.local 로 사용하세요.
#
# 로컬 개발: `pnpm db:start` (supabase start) 후 출력되는 값을 사용.
#   - URL/키는 `pnpm exec supabase status` 로도 확인 가능.
# 프로덕션: Supabase 프로젝트 대시보드(Settings > API)의 값으로 교체.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# 서버 전용 — RLS 우회. 절대 클라이언트 번들/공개 저장소에 노출하지 마세요.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
